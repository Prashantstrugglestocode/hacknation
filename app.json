{
  "expo": {
    "name": "City Wallet",
    "slug": "city-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cc.viss.citywallet",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "City Wallet braucht deinen ungefähren Standort, um lokale Angebote zu finden. Wir senden nur eine grobe 1,2 km Zelle.",
        "NSCameraUsageDescription": "Zum Scannen von Kunden-QR-Codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "cc.viss.citywallet",
      "permissions": ["ACCESS_FINE_LOCATION", "CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-camera",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "City Wallet braucht deinen ungefähren Standort, um lokale Angebote zu finden. Wir senden nur eine grobe 1,2 km Zelle."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://city-wallet-server.onrender.com",
      "supabaseUrl": "https://ecydsayjmyrbkxthkfli.supabase.co",
      "supabaseAnonKey": "sb_publishable_ynW6q0OGiqA1boYGWVmOVA_JnlvbZZ0",
      "eas": {
        "projectId": "city-wallet"
      }
    },
    "scheme": "citywallet"
  }
}
